<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Cleartext only to exact localhost/127.0.0.1 (dev dummy API). No subdomain wildcarding:
         includeSubdomains=true on "localhost" would also match e.g. foo.localhost which can be
         pointed anywhere via /etc/hosts, enabling MITM of API keys on a compromised dev setup. -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>
</network-security-config>
