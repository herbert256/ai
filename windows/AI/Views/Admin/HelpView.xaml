<UserControl x:Class="AI.Views.Admin.HelpView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel x:Name="HelpPanel" Margin="32,24,32,24" MaxWidth="700">
            <TextBlock Text="Help" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,24"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
