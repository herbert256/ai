<UserControl x:Class="AI.Views.Admin.StatisticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">
    <Grid Margin="32,24,32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="AI Usage" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,20"/>

        <!-- Summary cards -->
        <WrapPanel Grid.Row="1" x:Name="SummaryPanel" Margin="0,0,0,20"/>

        <!-- Provider groups -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="ProvidersPanel"/>
        </ScrollViewer>

        <!-- Clear button -->
        <Button Grid.Row="3" x:Name="ClearBtn" Content="Clear Statistics" HorizontalAlignment="Left"
                Margin="0,16,0,0" Padding="16,8" Click="ClearBtn_Click"
                Background="{StaticResource ErrorBrush}" Foreground="White"/>
    </Grid>
</UserControl>
