<UserControl x:Class="AI.Views.Admin.TraceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">
    <Grid Margin="24,16,24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="API Traces" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,12"/>

        <!-- Controls -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="SearchBox" Grid.Column="0" PlaceholderText="Search traces..."
                     Margin="0,0,8,0" TextChanged="SearchBox_TextChanged"/>
            <Button Grid.Column="1" Content="Refresh" Style="{StaticResource SecondaryButton}"
                    Margin="0,0,8,0" Click="RefreshBtn_Click"/>
            <Button Grid.Column="2" Content="Copy" Style="{StaticResource SecondaryButton}"
                    Margin="0,0,8,0" Click="CopyBtn_Click"/>
            <Button Grid.Column="3" Content="Clear All"
                    Background="{StaticResource ErrorBrush}" Foreground="White"
                    Click="ClearAllBtn_Click"/>
        </Grid>

        <!-- Main content -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left panel: trace list -->
            <Border Grid.Column="0" Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" CornerRadius="6">
                <ListBox x:Name="TraceList" SelectionChanged="TraceList_SelectionChanged"
                         Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,4,0,4">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Hostname}" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" MaxWidth="180"/>
                                    <TextBlock x:Name="StatusCodeText" Text="{Binding StatusCode, StringFormat=' [{0}]'}"
                                               Margin="4,0,0,0"/>
                                </StackPanel>
                                <TextBlock Text="{Binding Model}" FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}"
                                           FontSize="10"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <!-- Right panel: trace detail -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Tabs -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                    <Button x:Name="TabAll" Content="All" Margin="0,0,4,0" Click="TabAll_Click"/>
                    <Button x:Name="TabReqHeaders" Content="Request Headers" Style="{StaticResource SecondaryButton}"
                            Margin="0,0,4,0" Click="TabReqHeaders_Click"/>
                    <Button x:Name="TabResHeaders" Content="Response Headers" Style="{StaticResource SecondaryButton}"
                            Margin="0,0,4,0" Click="TabResHeaders_Click"/>
                    <Button x:Name="TabReqBody" Content="Request Body" Style="{StaticResource SecondaryButton}"
                            Margin="0,0,4,0" Click="TabReqBody_Click"/>
                    <Button x:Name="TabResBody" Content="Response Body" Style="{StaticResource SecondaryButton}"
                            Margin="0,0,4,0" Click="TabResBody_Click"/>
                </StackPanel>

                <Border Grid.Row="1" Background="{StaticResource CardBackgroundBrush}"
                        BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" CornerRadius="6"
                        Padding="12">
                    <TextBox x:Name="DetailBox" IsReadOnly="True"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas" FontSize="12"
                             Background="Transparent" BorderThickness="0"
                             Text="Select a trace to view details."/>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
