<UserControl x:Class="AI.Views.Chat.DualChatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="16,16,16,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Dual Chat" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,16"/>

        <!-- Two columns -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left panel -->
            <Border Grid.Column="0" Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="12,12,12,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="Provider1Combo" Grid.Column="0"
                                  SelectionChanged="Provider1Combo_SelectionChanged"/>
                        <ComboBox x:Name="Model1Combo" Grid.Column="2" IsEditable="True"/>
                    </Grid>
                    <TextBlock Grid.Row="1" x:Name="Status1Text" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="12,0,12,8"/>
                    <ScrollViewer Grid.Row="2" x:Name="Scroll1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,0">
                        <StackPanel x:Name="Messages1Panel" Margin="12,0,12,12"/>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Right panel -->
            <Border Grid.Column="2" Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="12,12,12,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="Provider2Combo" Grid.Column="0"
                                  SelectionChanged="Provider2Combo_SelectionChanged"/>
                        <ComboBox x:Name="Model2Combo" Grid.Column="2" IsEditable="True"/>
                    </Grid>
                    <TextBlock Grid.Row="1" x:Name="Status2Text" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="12,0,12,8"/>
                    <ScrollViewer Grid.Row="2" x:Name="Scroll2" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="Messages2Panel" Margin="12,0,12,12"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- Shared input -->
        <Grid Grid.Row="2" Margin="0,12,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="SharedInput" Grid.Column="0" PlaceholderText="Message both assistants..."
                     AcceptsReturn="True" TextWrapping="Wrap" MinHeight="44" MaxHeight="100"
                     VerticalScrollBarVisibility="Auto" Margin="0,0,8,0"/>
            <Button x:Name="SendBothBtn" Grid.Column="1" Content="Send Both" Width="100"
                    Click="SendBothBtn_Click"/>
        </Grid>

        <Button Grid.Row="3" Content="Clear Both" Style="{StaticResource SecondaryButton}"
                HorizontalAlignment="Right" Click="ClearBothBtn_Click"/>
    </Grid>
</UserControl>
