<UserControl x:Class="AI.Views.HubView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24,32,24">
            <TextBlock Text="Hub" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <TextBlock x:Name="GreetingText" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,24"/>

            <!-- Stat cards -->
            <WrapPanel x:Name="StatsPanel" Margin="0,0,0,32"/>

            <!-- Quick actions -->
            <TextBlock Text="QUICK ACTIONS" FontSize="11" FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>
            <StackPanel Orientation="Horizontal">
                <Button x:Name="NewReportBtn" Content="New Report" Width="130" Margin="0,0,12,0"
                        Click="NewReportBtn_Click"/>
                <Button x:Name="ChatBtn" Content="Chat" Width="100" Margin="0,0,12,0"
                        Style="{StaticResource SecondaryButton}" Click="ChatBtn_Click"/>
                <Button x:Name="SetupBtn" Content="AI Setup" Width="100"
                        Style="{StaticResource SecondaryButton}" Click="SetupBtn_Click"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
