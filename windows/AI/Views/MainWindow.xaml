<Window x:Class="AI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:AI.Views"
        xmlns:reports="clr-namespace:AI.Views.Reports"
        xmlns:chat="clr-namespace:AI.Views.Chat"
        xmlns:models="clr-namespace:AI.Views.Models"
        xmlns:history="clr-namespace:AI.Views.History"
        xmlns:settings="clr-namespace:AI.Views.Settings"
        xmlns:admin="clr-namespace:AI.Views.Admin"
        Title="AI" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="1" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBackgroundBrush}">
            <DockPanel>
                <!-- App Title -->
                <Border DockPanel.Dock="Top" Padding="16,16,16,8">
                    <TextBlock Text="AI" FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}" />
                </Border>

                <!-- Navigation -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="SidebarItems" />
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Divider -->
        <Border Grid.Column="1" Background="{StaticResource CardBorderBrush}" />

        <!-- Content Area -->
        <ContentControl Grid.Column="2" x:Name="ContentArea" />
    </Grid>
</Window>
