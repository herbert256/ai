<UserControl x:Class="AI.Views.Reports.ReportParametersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">
    <Grid Margin="24,16,24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Report Parameters" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,16"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Border Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" CornerRadius="6"
                    Padding="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Row 0: Temperature / Max Tokens -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,12">
                        <TextBlock Text="Temperature (0.0 - 2.0)" Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,4"/>
                        <TextBox x:Name="TempBox"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,12">
                        <TextBlock Text="Max Tokens" Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,4"/>
                        <TextBox x:Name="MaxTokensBox"/>
                    </StackPanel>

                    <!-- Row 1: Top P / Top K -->
                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,12">
                        <TextBlock Text="Top P" Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,4"/>
                        <TextBox x:Name="TopPBox"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,12">
                        <TextBlock Text="Top K" Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,4"/>
                        <TextBox x:Name="TopKBox"/>
                    </StackPanel>

                    <!-- Row 2: Frequency Penalty / Presence Penalty -->
                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,12">
                        <TextBlock Text="Frequency Penalty" Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,4"/>
                        <TextBox x:Name="FreqPenBox"/>
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,12">
                        <TextBlock Text="Presence Penalty" Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,4"/>
                        <TextBox x:Name="PresencePenBox"/>
                    </StackPanel>

                    <!-- Row 3: Seed -->
                    <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,0,12">
                        <TextBlock Text="Seed" Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,4"/>
                        <TextBox x:Name="SeedBox"/>
                    </StackPanel>

                    <!-- Row 4: System Prompt (full width) -->
                    <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,12">
                        <TextBlock Text="System Prompt" Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,4"/>
                        <TextBox x:Name="SystemPromptBox" AcceptsReturn="True" TextWrapping="Wrap"
                                 Height="100" VerticalScrollBarVisibility="Auto"
                                 VerticalContentAlignment="Top"/>
                    </StackPanel>

                    <!-- Row 5: Checkboxes -->
                    <StackPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,4">
                        <CheckBox x:Name="JsonFormatCheck" Content="JSON Response Format" Margin="0,0,0,8"/>
                        <CheckBox x:Name="SearchEnabledCheck" Content="Search Enabled" Margin="0,0,0,8"/>
                        <CheckBox x:Name="ReturnCitationsCheck" Content="Return Citations" Margin="0,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </ScrollViewer>

        <!-- Footer buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Clear" Style="{StaticResource SecondaryButton}"
                    Margin="0,0,8,0" Click="ClearBtn_Click"/>
            <Button Content="Apply" Click="ApplyBtn_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
