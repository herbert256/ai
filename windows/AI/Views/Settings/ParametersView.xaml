<UserControl x:Class="AI.Views.Settings.ParametersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24,16,24,16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- List -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="Parameters" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,12"/>
            <Button Grid.Row="1" Content="+ New Preset" Margin="0,0,0,8" Click="NewBtn_Click"/>
            <Border Grid.Row="2" Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" CornerRadius="6">
                <ListBox x:Name="ParamList" SelectionChanged="ParamList_SelectionChanged"
                         DisplayMemberPath="Name" Background="Transparent" BorderThickness="0"/>
            </Border>
        </Grid>

        <!-- Edit form -->
        <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,0,24">
                <TextBlock x:Name="FormTitle" Text="Select a preset" FontSize="18"
                           FontWeight="SemiBold" Margin="0,0,0,16"/>

                <TextBlock Text="Name" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                <TextBox x:Name="NameBox" Margin="0,0,0,12"/>

                <TextBlock Text="Temperature (0.0 - 2.0)" Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,4"/>
                <TextBox x:Name="TempBox" Margin="0,0,0,12"/>

                <TextBlock Text="Max Tokens" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                <TextBox x:Name="MaxTokensBox" Margin="0,0,0,12"/>

                <TextBlock Text="Top P" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                <TextBox x:Name="TopPBox" Margin="0,0,0,12"/>

                <TextBlock Text="Top K" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                <TextBox x:Name="TopKBox" Margin="0,0,0,12"/>

                <TextBlock Text="Frequency Penalty" Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,4"/>
                <TextBox x:Name="FreqPenBox" Margin="0,0,0,12"/>

                <TextBlock Text="Presence Penalty" Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,4"/>
                <TextBox x:Name="PresencePenBox" Margin="0,0,0,12"/>

                <CheckBox x:Name="JsonModeCheck" Content="JSON Response Format" Margin="0,0,0,8"/>
                <CheckBox x:Name="SearchCheck" Content="Search Enabled" Margin="0,0,0,16"/>

                <StackPanel Orientation="Horizontal">
                    <Button Content="Save" Margin="0,0,8,0" Click="SaveBtn_Click"/>
                    <Button Content="Delete" Style="{StaticResource DangerButton}" Click="DeleteBtn_Click"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
